{
  "name": "TimeBadge",
  "description": "Displays the current time as a Chrome Extension badge.",
  "version": "0.0.5",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/light-mode/icon16.png",
    "32": "icons/light-mode/icon32.png",
    "48": "icons/light-mode/icon48.png",
    "128": "icons/light-mode/icon128.png"
  },
  "action": {
    "default_title": "TimeBadge",
    "default_icon": {
      "16": "icons/light-mode/icon16.png",
      "32": "icons/light-mode/icon32.png"
    }
  },
  "permissions": [
    "idle",
    "storage"
  ]
}
